// Serial-Based Second-Hand Electronics Management Schema
// Specialized for IMEI/Serial tracking, QC grading, and asset lifecycle

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ===========================
// IDENTITY & ACCESS MANAGEMENT
// ===========================

enum UserRole {
  SUPER_ADMIN
  QC_INSPECTOR
  INVENTORY_MANAGER
  TECHNICIAN
  CASHIER
  ACCOUNTANT
}

model User {
  id       String   @id @default(cuid()) @map("_id")
  email    String   @unique
  password String
  fullName String
  role     UserRole @default(CASHIER)
  isActive Boolean  @default(true)

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  qcInspections      QCInspection[]
  serialTransactions SerialTransaction[]
  refurbishmentJobs  RefurbishmentJob[]
  salesOrders        SalesOrder[]
  inboundRequests    InboundRequest[]
  stockMovements     StockMovement[]

  @@map("users")
}

// ===========================
// PRODUCT CATALOG (Template-based)
// ===========================

enum ProductType {
  ELECTRONICS
  APPLIANCE_LARGE
  APPLIANCE_SMALL
  COMPUTER
  ACCESSORY
}

enum TrackingMethod {
  SERIAL_BASED
  QUANTITY_BASED
}

model Category {
  id             String         @id @default(cuid()) @map("_id")
  name           String
  code           String         @unique
  productType    ProductType
  trackingMethod TrackingMethod @default(SERIAL_BASED)
  description    String?
  parentId       String?

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Category[] @relation("CategoryHierarchy")

  productTemplates ProductTemplate[]
  attributeGroups  AttributeGroup[]
  qcTemplates      QCTemplate[]
  inboundItems     InboundItem[]
  brandCategories  BrandCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Brand {
  id   String  @id @default(cuid()) @map("_id")
  name String  @unique
  code String  @unique
  logo String?

  productTemplates ProductTemplate[]
  inboundItems     InboundItem[]
  brandCategories  BrandCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("brands")
}

model BrandCategory {
  id         String   @id @default(cuid()) @map("_id")
  brandId    String
  categoryId String
  assignedAt DateTime @default(now())

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([brandId, categoryId])
  @@index([categoryId])
  @@index([brandId])
  @@map("brand_categories")
}

model ProductTemplate {
  id          String  @id @default(cuid()) @map("_id")
  sku         String  @unique
  name        String
  model       String?
  description String?
  categoryId  String
  brandId     String

  baseWholesalePrice Float?
  baseRetailPrice    Float?

  image    String?
  isActive Boolean @default(true)

  category Category @relation(fields: [categoryId], references: [id])
  brand    Brand    @relation(fields: [brandId], references: [id])

  serialItems    SerialItem[]
  staticSpecs    ProductSpec[]
  inboundItems   InboundItem[]
  stockLevels    StockLevel[]
  stockMovements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_templates")
}

// ===========================
// DYNAMIC ATTRIBUTES SYSTEM (EAV Pattern)
// ===========================

enum AttributeType {
  TEXT
  NUMBER
  DECIMAL
  BOOLEAN
  SELECT
  MULTISELECT
  DATE
}

model AttributeGroup {
  id          String  @id @default(cuid()) @map("_id")
  categoryId  String
  name        String
  description String?
  sortOrder   Int     @default(0)

  category   Category    @relation(fields: [categoryId], references: [id])
  attributes Attribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attribute_groups")
}

model Attribute {
  id               String        @id @default(cuid()) @map("_id")
  attributeGroupId String
  key              String
  name             String
  type             AttributeType
  isRequired       Boolean       @default(false)
  sortOrder        Int           @default(0)

  options  Json?
  minValue Float?
  maxValue Float?

  attributeGroup AttributeGroup @relation(fields: [attributeGroupId], references: [id])
  productSpecs   ProductSpec[]
  dynamicSpecs   DynamicSpec[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attributeGroupId, key])
  @@map("attributes")
}

model ProductSpec {
  id                String @id @default(cuid()) @map("_id")
  productTemplateId String
  attributeId       String
  value             Json

  productTemplate ProductTemplate @relation(fields: [productTemplateId], references: [id], onDelete: Cascade)
  attribute       Attribute       @relation(fields: [attributeId], references: [id])

  @@unique([productTemplateId, attributeId])
  @@map("product_specs")
}

// ===========================
// SERIAL ITEM MANAGEMENT
// ===========================

enum SerialStatus {
  INCOMING
  QC_IN_PROGRESS
  AVAILABLE
  RESERVED
  SOLD
  REFURBISHING
  DAMAGED
  RETURNED
  DISPOSED
}

enum Grade {
  GRADE_A_NEW
  GRADE_A
  GRADE_B_PLUS
  GRADE_B
  GRADE_C_PLUS
  GRADE_C
  GRADE_D
}

model SerialItem {
  id                String @id @default(cuid()) @map("_id")
  productTemplateId String

  serialNumber String? @unique
  internalCode String  @unique

  source        String?
  purchasePrice Float
  purchaseDate  DateTime?
  purchaseBatch String?

  status         SerialStatus @default(INCOMING)
  grade          Grade?
  conditionNotes String?

  currentCostPrice Float @default(0)
  suggestedPrice   Float @default(0)

  warehouseId String
  binLocation String?

  productTemplate ProductTemplate @relation(fields: [productTemplateId], references: [id])
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id])

  qcInspections     QCInspection[]
  dynamicSpecs      DynamicSpec[]
  transactions      SerialTransaction[]
  refurbishmentJobs RefurbishmentJob[]
  salesOrderItems   SalesOrderItem[]
  inboundItem       InboundItem?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("serial_items")
}

model DynamicSpec {
  id           String   @id @default(cuid()) @map("_id")
  serialItemId String
  attributeId  String
  value        Json
  recordedAt   DateTime @default(now())
  recordedById String?

  serialItem SerialItem @relation(fields: [serialItemId], references: [id], onDelete: Cascade)
  attribute  Attribute  @relation(fields: [attributeId], references: [id])

  @@index([serialItemId, attributeId, recordedAt])
  @@map("dynamic_specs")
}

// ===========================
// QC & INSPECTION SYSTEM
// ===========================

model QCTemplate {
  id          String  @id @default(cuid()) @map("_id")
  categoryId  String
  name        String
  description String?
  version     String  @default("1.0")
  isActive    Boolean @default(true)

  category    Category       @relation(fields: [categoryId], references: [id])
  checkItems  QCCheckItem[]
  inspections QCInspection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("qc_templates")
}

enum CheckItemType {
  VISUAL_CHECK
  FUNCTION_TEST
  MEASUREMENT
  ACCESSORY_COUNT
}

model QCCheckItem {
  id          String        @id @default(cuid()) @map("_id")
  templateId  String
  section     String
  item        String
  type        CheckItemType
  description String?
  isRequired  Boolean       @default(false)
  sortOrder   Int           @default(0)

  maxScore      Int   @default(100)
  gradingImpact Float @default(1.0)

  template QCTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results  QCInspectionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("qc_check_items")
}

enum InspectionStatus {
  PENDING
  COMPLETED
  FAILED
}

model QCInspection {
  id           String           @id @default(cuid()) @map("_id")
  serialItemId String
  templateId   String
  inspectorId  String
  status       InspectionStatus @default(PENDING)

  totalScore     Float?
  suggestedGrade Grade?
  finalGrade     Grade?
  notes          String?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  serialItem SerialItem         @relation(fields: [serialItemId], references: [id])
  template   QCTemplate         @relation(fields: [templateId], references: [id])
  inspector  User               @relation(fields: [inspectorId], references: [id])
  items      QCInspectionItem[]

  @@map("qc_inspections")
}

model QCInspectionItem {
  id           String @id @default(cuid()) @map("_id")
  inspectionId String
  checkItemId  String

  score  Int?
  passed Boolean @default(true)
  notes  String?
  photos Json?

  inspection QCInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  checkItem  QCCheckItem  @relation(fields: [checkItemId], references: [id])

  checkedAt DateTime @default(now())

  @@unique([inspectionId, checkItemId])
  @@map("qc_inspection_items")
}

// ===========================
// WAREHOUSE & LOCATION
// ===========================

model Warehouse {
  id       String  @id @default(cuid()) @map("_id")
  code     String  @unique
  name     String
  address  String?
  phone    String?
  isActive Boolean @default(true)

  totalArea   Float?
  maxCapacity Int?

  serialItems     SerialItem[]
  binLocations    BinLocation[]
  salesOrders     SalesOrder[]
  inboundRequests InboundRequest[]
  stockLevels     StockLevel[]
  stockMovements  StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("warehouses")
}

enum LocationType {
  SHELF
  FLOOR
  CABINET
  REPAIR
  QC_AREA
}

model BinLocation {
  id          String       @id @default(cuid()) @map("_id")
  warehouseId String
  code        String
  name        String
  type        LocationType @default(SHELF)

  maxItems  Int?
  maxWeight Float?

  currentItems Int     @default(0)
  isActive     Boolean @default(true)

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([warehouseId, code])
  @@map("bin_locations")
}

// ===========================
// REFURBISHMENT & REPAIR
// ===========================

enum RefurbStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

model RefurbishmentJob {
  id           String       @id @default(cuid()) @map("_id")
  serialItemId String
  technicianId String
  status       RefurbStatus @default(PLANNED)

  issuesFound   String
  plannedWork   String
  estimatedCost Float

  actualWork String?
  actualCost Float   @default(0)

  startedAt   DateTime?
  completedAt DateTime?

  serialItem SerialItem  @relation(fields: [serialItemId], references: [id])
  technician User        @relation(fields: [technicianId], references: [id])
  partUsages PartUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("refurbishment_jobs")
}

model PartUsage {
  id       String  @id @default(cuid()) @map("_id")
  jobId    String
  partName String
  quantity Int     @default(1)
  unitCost Float

  job RefurbishmentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("part_usages")
}

// ===========================
// TRANSACTION & MOVEMENT TRACKING
// ===========================

enum TransactionType {
  INBOUND
  QC_START
  QC_COMPLETE
  MOVE_TO_REFURB
  REFURB_COMPLETE
  MOVE_TO_SALE
  RESERVED
  SOLD
  RETURNED
  DISPOSAL
}

model SerialTransaction {
  id           String          @id @default(cuid()) @map("_id")
  serialItemId String
  type         TransactionType

  fromLocation String?
  toLocation   String?

  fromStatus SerialStatus?
  toStatus   SerialStatus?

  costChange Float?

  notes         String?
  performedById String

  serialItem  SerialItem @relation(fields: [serialItemId], references: [id], onDelete: Cascade)
  performedBy User       @relation(fields: [performedById], references: [id])

  createdAt DateTime @default(now())

  @@index([serialItemId, createdAt])
  @@map("serial_transactions")
}

// ===========================
// SALES
// ===========================

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  DELIVERED
  COMPLETED
  CANCELLED
}

model Customer {
  id       String  @id @default(cuid()) @map("_id")
  code     String  @unique
  fullName String
  phone    String?
  email    String?
  address  String?

  salesOrders SalesOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

model SalesOrder {
  id          String           @id @default(cuid()) @map("_id")
  code        String           @unique
  customerId  String?
  warehouseId String
  status      SalesOrderStatus @default(DRAFT)

  totalAmount Float
  paidAmount  Float @default(0)

  notes         String?
  salesPersonId String?

  customer    Customer?        @relation(fields: [customerId], references: [id])
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  salesPerson User?            @relation(fields: [salesPersonId], references: [id])
  items       SalesOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sales_orders")
}

model SalesOrderItem {
  id           String @id @default(cuid()) @map("_id")
  salesOrderId String
  serialItemId String

  unitPrice  Float
  discount   Float @default(0)
  finalPrice Float

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  serialItem SerialItem @relation(fields: [serialItemId], references: [id])

  @@unique([salesOrderId, serialItemId])
  @@map("sales_order_items")
}

// ===========================
// SUPPLIER MANAGEMENT
// ===========================

model Supplier {
  id            String  @id @default(cuid()) @map("_id")
  code          String  @unique
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  taxCode       String?
  bankAccount   String?
  notes         String?
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("suppliers")
}

// ===========================
// INBOUND/RECEIVING MODULE
// ===========================

enum InboundStatus {
  REQUESTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SupplierType {
  CUSTOMER_TRADE_IN
  INTERNAL_RETURN
  LIQUIDATION
  INDIVIDUAL_SELLER
}

model InboundRequest {
  id           String        @id @default(cuid()) @map("_id")
  code         String        @unique
  warehouseId  String
  status       InboundStatus @default(REQUESTED)

  supplierType  SupplierType
  supplierName  String
  supplierPhone String?
  supplierEmail String?

  expectedDate DateTime?
  receivedDate DateTime?

  totalEstimatedValue Float?
  totalActualValue    Float?

  notes        String?
  receivedById String?

  warehouse  Warehouse     @relation(fields: [warehouseId], references: [id])
  receivedBy User?         @relation(fields: [receivedById], references: [id])
  items      InboundItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, expectedDate])
  @@map("inbound_requests")
}

model InboundItem {
  id               String  @id @default(cuid()) @map("_id")
  inboundRequestId String

  productTemplateId String?
  categoryId        String
  brandId           String?

  serialNumber String?
  modelName    String
  condition    String?

  estimatedValue Float?
  notes          String?

  sourceCustomerName    String?
  sourceCustomerPhone   String?
  sourceCustomerAddress String?
  sourceCustomerIdCard  String?
  idCardIssueDate       DateTime?
  idCardIssuePlace      String?
  bankAccount           String?
  bankName              String?

  contractNumber String?
  purchaseDate   DateTime?
  employeeName   String?

  otherCosts   Float?
  topUp        Float?
  repairCost   Float?
  imageUrl     String?
  deviceImages String?
  cccdFrontUrl String?
  cccdBackUrl  String?

  isReceived Boolean   @default(false)
  receivedAt DateTime?

  serialItemId String? @unique

  inboundRequest  InboundRequest   @relation(fields: [inboundRequestId], references: [id], onDelete: Cascade)
  productTemplate ProductTemplate? @relation(fields: [productTemplateId], references: [id])
  category        Category         @relation(fields: [categoryId], references: [id])
  brand           Brand?           @relation(fields: [brandId], references: [id])
  serialItem      SerialItem?      @relation(fields: [serialItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inboundRequestId, isReceived])
  @@map("inbound_items")
}

// ===========================
// STOCK LEVEL & MOVEMENT TRACKING
// ===========================

model StockLevel {
  id                String @id @default(cuid()) @map("_id")
  productTemplateId String
  warehouseId       String
  grade             Grade?

  physicalQty     Int @default(0)
  incomingQty     Int @default(0)
  qcInProgressQty Int @default(0)
  availableQty    Int @default(0)
  reservedQty     Int @default(0)
  refurbishingQty Int @default(0)
  damagedQty      Int @default(0)
  returnedQty     Int @default(0)

  averageCost Float
  totalValue  Float

  minStockLevel Int @default(5)
  maxStockLevel Int @default(100)
  reorderPoint  Int @default(10)

  productTemplate ProductTemplate @relation(fields: [productTemplateId], references: [id], onDelete: Cascade)
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  lastUpdated DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([productTemplateId, warehouseId, grade])
  @@index([warehouseId, availableQty])
  @@index([productTemplateId, physicalQty])
  @@map("stock_levels")
}

enum MovementType {
  IN
  OUT
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT
  RESERVE
  UNRESERVE
}

model StockMovement {
  id                String       @id @default(cuid()) @map("_id")
  productTemplateId String
  warehouseId       String

  type     MovementType
  quantity Int

  referenceType String?
  referenceId   String?
  serialItemId  String?

  unitCost   Float
  totalValue Float

  balanceBefore Int
  balanceAfter  Int

  notes       String?
  createdById String

  productTemplate ProductTemplate @relation(fields: [productTemplateId], references: [id], onDelete: Cascade)
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy       User            @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([productTemplateId, warehouseId, createdAt])
  @@index([referenceType, referenceId])
  @@index([serialItemId])
  @@map("stock_movements")
}
