{
  "version": 2,
  "installCommand": "NODE_ENV=development pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "devCommand": "cd apps/web && pnpm dev",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": [
        "apps/backend/dist/**",
        "node_modules/.prisma/client/**",
        "node_modules/@prisma/client/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
