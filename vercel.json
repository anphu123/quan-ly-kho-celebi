{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "cd apps/web && pnpm build && cd ../backend && pnpm exec prisma generate && pnpm exec nest build",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "devCommand": "cd apps/web && pnpm dev",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "apps/backend/dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
